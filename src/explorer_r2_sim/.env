# ROS 2 + Gazebo pairing read by docker-compose.yml.
#
# Default: Jazzy + Harmonic — matches the gz-sim-*-system plugin filenames in
# worlds/cave.sdf.
#
# Switch to Humble + Fortress by uncommenting the second triple AND swapping
# the plugin filenames in worlds/cave.sdf to ignition-gazebo-*-system.

ROS_DISTRO=jazzy
GZ_PKG=gz-harmonic
GZ_CMD=gz sim

# ROS_DISTRO=humble
# GZ_PKG=ignition-fortress
# GZ_CMD=ign gazebo

# Shared DDS namespace.
ROS_DOMAIN_ID=42
